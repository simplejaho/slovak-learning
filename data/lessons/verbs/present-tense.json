  "exercises": [
    { "sk": "Ja pozerám televíziu.", "en": "I watch TV." },
    { "sk": "Ty hovoríš po slovensky.", "en": "You speak Slovak." },
    { "sk": "On pracuje doma.", "en": "He works at home." },
    { "sk": "My rozumieme tomu.", "en": "We understand it." },
