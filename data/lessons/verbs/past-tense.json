    {
      "title": "Aspect in Past Tense - Imperfective",
      "text": "Imperfective verbs in past tense describe ongoing, repeated, or habitual actions in the past without focus on completion. They answer 'what was happening' or 'what used to happen'.",
      "examples": [
        "Čítal som knihu – I was reading a book (ongoing)",
        "Pracoval každý deň – He worked every day (habitual)",
        "Učili sme sa slovenčinu – We were learning Slovak (process)"
      ]
    },
    {
      "title": "Aspect in Past Tense - Perfective",
      "text": "Perfective verbs in past tense describe completed actions with a clear result or endpoint. They answer 'what happened' or 'what got done'.",
      "examples": [
        "Prečítal som knihu – I read the book (finished it)",
        "Napísal list – He wrote a letter (completed)",
        "Kúpili sme auto – We bought a car (completed action)"
      ]
    },
    {
      "title": "Aspect Pairs in Past Tense",
      "text": "Most verbs come in aspect pairs. Use imperfective for process/duration, perfective for completion. Both use the same past tense formation rules.",
      "table": {
        "headers": ["Imperfective", "Meaning", "Perfective", "Meaning"],
        "rows": [
          ["písal som", "I was writing", "napísal som", "I wrote (completed)"],
          ["jedol som", "I was eating", "zjedol som", "I ate it all up"],
          ["čítal som", "I was reading", "prečítal som", "I read (finished)"],
          ["robil som", "I was doing", "urobil som", "I did (completed)"],
          ["učil som sa", "I was learning", "naučil som sa", "I learned (finished)"]
        ]
      },
      "examples": [
        "Písal som (imp.) – I was writing",
        "Napísal som (perf.) – I wrote/finished writing",
        "Jedol som (imp.) – I was eating",
        "Zjedol som (perf.) – I ate it all up"
      ]
    },
