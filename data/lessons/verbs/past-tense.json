{
  "rules": [
    {
      "title": "Past Tense Formation - Basic Structure",
      "text": "Slovak past tense is formed using the past participle (l-participle) + present tense of 'byť' (to be) as auxiliary. The participle agrees with gender and number: -l (masculine singular), -la (feminine singular), -lo (neuter singular), -li (masculine plural), -ly (feminine/neuter plural).",
      "examples": [
        "robil som – I did (masculine speaker)",
        "robila som – I did (feminine speaker)",
        "robili sme – we did"
      ]
    },
    {
      "title": "Past Tense Conjugation - 'robiť' (to do)",
      "text": "Full conjugation table for imperfective verb 'robiť':",
      "table": {
        "headers": ["Person", "Masculine", "Feminine", "Plural"],
        "rows": [
          ["JA (I)", "robil som", "robila som", "robili sme"],
          ["TY (you sg.)", "robil si", "robila si", "robili ste"],
          ["ON/ONA/ONO (he/she/it)", "robil", "robila", "robilo"],
          ["MY (we)", "robili sme", "robili sme", "robili sme"],
          ["VY (you pl./formal)", "robili ste", "robili ste", "robili ste"],
          ["ONI/ONY (they)", "robili", "robili", "robili"]
        ]
      },
      "examples": [
        "Ja som robil domácu úlohu – I did homework (masc.)",
        "Ty si robila chybu – You made a mistake (fem.)",
        "Oni robili projekt – They did a project"
      ]
    },
    {
      "title": "Past Tense Conjugation - 'napísať' (to write - perfective)",
      "text": "Full conjugation table for perfective verb 'napísať':",
      "table": {
        "headers": ["Person", "Masculine", "Feminine", "Plural"],
        "rows": [
          ["JA", "napísal som", "napísala som", "napísali sme"],
          ["TY", "napísal si", "napísala si", "napísali ste"],
          ["ON/ONA/ONO", "napísal", "napísala", "napísalo"],
          ["MY", "napísali sme", "napísali sme", "napísali sme"],
          ["VY", "napísali ste", "napísali ste", "napísali ste"],
          ["ONI/ONY", "napísali", "napísali", "napísali"]
        ]
      },
      "examples": [
        "Napísal som list – I wrote a letter (completed)",
        "Napísala si email – You wrote an email (completed)",
        "Napísali sme knihu – We wrote a book (completed)"
      ]
    },
    {
      "title": "Auxiliary Verb 'byť' - Often Omitted in 3rd Person",
      "text": "In 3rd person (on, ona, ono, oni, ony), the auxiliary 'bol/bola/bolo/boli' is often omitted in standard speech. It's included for emphasis or clarity.",
      "examples": [
        "On robil – He did (standard)",
        "On bol robil – He did (emphatic)",
        "Ona čítala – She read",
        "Oni pracovali – They worked"
      ]
    },
    {
      "title": "Reflexive Verbs in Past Tense",
      "text": "Reflexive verbs use 'sa' or 'si' with past tense. The reflexive particle comes after the auxiliary verb (or after the participle in 3rd person). Word order: subject + auxiliary + reflexive + participle.",
      "examples": [
        "Učil som sa – I learned (masc.)",
        "Učila som sa – I learned (fem.)",
        "Umyl si sa – You washed yourself (masc.)",
        "Umyla si sa – You washed yourself (fem.)",
        "Učil sa – He learned",
        "Učili sme sa – We learned"
      ]
    },
    {
      "title": "Reflexive Conjugation Table - 'učiť sa' (to learn)",
      "text": "Full conjugation with reflexive particle:",
      "table": {
        "headers": ["Person", "Masculine", "Feminine", "Plural"],
        "rows": [
          ["JA", "učil som sa", "učila som sa", "učili sme sa"],
          ["TY", "učil si sa", "učila si sa", "učili ste sa"],
          ["ON/ONA/ONO", "učil sa", "učila sa", "učilo sa"],
          ["MY", "učili sme sa", "učili sme sa", "učili sme sa"],
          ["VY", "učili ste sa", "učili ste sa", "učili ste sa"],
          ["ONI/ONY", "učili sa", "učili sa", "učili sa"]
        ]
      },
      "examples": [
        "Učil som sa slovenčinu – I learned Slovak (masc.)",
        "Učila si sa celý deň – You studied all day (fem.)",
        "Učili sa spolu – They studied together"
      ]
    },
    {
      "title": "Negation in Past Tense",
      "text": "Add 'ne-' prefix to the participle. The auxiliary verb remains unchanged. In 3rd person, you can also negate the omitted auxiliary (nebol/nebola/neboli).",
      "examples": [
        "Nerobil som – I didn't do (masc.)",
        "Nerobila som – I didn't do (fem.)",
        "Nerobil si – You didn't do (masc.)",
        "Nerobil – He didn't do",
        "Nerobili sme – We didn't do"
      ]
    },
