{
  "rules": [
    {
      "title": "Understanding Prefixes",
      "text": "Prefixes in Slovak modify the meaning of the verb, often indicating direction, completion, repetition, or negation. Many prefixes turn imperfective verbs into perfective ones, but some preserve the imperfective aspect. Use the list below to see common prefixes and their effects.",
      "prefixes": [
        {"prefix":"u-", "meaning":"achieving goal/completion", "example":"urobiť", "root":"robiť", "rootMeaning":"to do/make", "combinedMeaning":"to complete/accomplish"},
        {"prefix":"pri-", "meaning":"towards, attachment", "example":"priísť", "root":"ísť", "rootMeaning":"to go", "combinedMeaning":"to come (go towards)"},
        {"prefix":"po-", "meaning":"brief/small action", "example":"pospať", "root":"spať", "rootMeaning":"to sleep", "combinedMeaning":"to sleep a little"},
        {"prefix":"roz-", "meaning":"spreading, division", "example":"rozdeliť", "root":"deliť", "rootMeaning":"to divide", "combinedMeaning":"to split apart/distribute"},
        {"prefix":"v-/vo-", "meaning":"inward movement", "example":"vojsť", "root":"ísť", "rootMeaning":"to go", "combinedMeaning":"to enter (go in)"},
        {"prefix":"za-", "meaning":"behind, beginning", "example":"začať", "root":"čať", "rootMeaning":"(bound root)", "combinedMeaning":"to begin"},
        {"prefix":"o-/ob-", "meaning":"around, about", "example":"obísť", "root":"ísť", "rootMeaning":"to go", "combinedMeaning":"to go around"},
        {"prefix":"vz-", "meaning":"upward, sudden", "example":"vzlietnuť", "root":"lietať", "rootMeaning":"to fly", "combinedMeaning":"to take off (fly up)"},
        {"prefix":"s-/so-", "meaning":"together, down", "example":"spojiť", "root":"pojiť", "rootMeaning":"to join", "combinedMeaning":"to connect together"},
        {"prefix":"nad-", "meaning":"above, superiority", "example":"nadbehnúť", "root":"behnúť", "rootMeaning":"to run", "combinedMeaning":"to run ahead/intercept"},
        {"prefix":"pod-", "meaning":"under, secretly", "example":"podliezť", "root":"liezť", "rootMeaning":"to crawl", "combinedMeaning":"to crawl under"},
        {"prefix":"bez-", "meaning":"without, lacking", "example":"bez-mocný", "root":"moc", "rootMeaning":"power", "combinedMeaning":"powerless"},
        {"prefix":"ne-", "meaning":"negation", "example":"nechcieť", "root":"chcieť", "rootMeaning":"to want", "combinedMeaning":"to not want"},
        {"prefix":"pro-", "meaning":"forward, in favor", "example":"prospievať", "root":"spievať", "rootMeaning":"to sing/thrive", "combinedMeaning":"to prosper"},
        {"prefix":"pre-", "meaning":"through, over", "example":"prebiehať", "root":"behať", "rootMeaning":"to run", "combinedMeaning":"to run across/through"}
      ]
    },
    {
      "title": "Key Rules",
      "text": "1. Most prefixed verbs are perfective.\n2. Some prefixes preserve imperfective meaning when combined with certain roots.\n3. Imperfective verbs indicate ongoing or repeated action; perfective verbs indicate completed action."
    }
  ],

