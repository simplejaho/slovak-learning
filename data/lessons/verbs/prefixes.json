{
  "rules": [
    {
      "title": "Understanding Prefixes",
      "text": "Prefixes in Slovak modify the meaning of the verb, often indicating direction, completion, repetition, or negation. Many prefixes turn imperfective verbs into perfective ones, but some preserve the imperfective aspect. Use the table below to see common prefixes and their effects.",
      "table": {
        "headers": ["Prefix", "Meaning", "Example", "Root", "Root Meaning", "Combined Meaning"],
        "rows": [
          ["u-", "achieving goal/completion", "urobiť", "robiť", "to do/make", "to complete/accomplish"],
          ["pri-", "towards, attachment", "priísť", "ísť", "to go", "to come (go towards)"],
          ["po-", "brief/small action", "pospať", "spať", "to sleep", "to sleep a little"],
          ["roz-", "spreading, division", "rozdeliť", "deliť", "to divide", "to split apart/distribute"],
          ["v-/vo-", "inward movement", "vojsť", "ísť", "to go", "to enter (go in)"],
          ["za-", "behind, beginning", "začať", "čať", "(bound root)", "to begin"],
          ["o-/ob-", "around, about", "obísť", "ísť", "to go", "to go around"],
          ["vz-", "upward, sudden", "vzlietnuť", "lietať", "to fly", "to take off (fly up)"],
          ["s-/so-", "together, down", "spojiť", "pojiť", "to join", "to connect together"],
          ["nad-", "above, superiority", "nadbehnúť", "behnúť", "to run", "to run ahead/intercept"],
          ["pod-", "under, secretly", "podliezť", "liezť", "to crawl", "to crawl under"],
          ["bez-", "without, lacking", "bez-mocný", "moc", "power", "powerless"],
          ["ne-", "negation", "nechcieť", "chcieť", "to want", "to not want"],
          ["pro-", "forward, in favor", "prospievať", "spievať", "to sing/thrive", "to prosper"],
          ["pre-", "through, over", "prebiehať", "behať", "to run", "to run across/through"]
        ]
      }
    }
  ],
