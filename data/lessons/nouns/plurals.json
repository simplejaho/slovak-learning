    {
      "title": "Masculine Plurals - Hard Consonants with +i",
      "text": "Masculine animate nouns (people, animals) with hard consonant stems typically add -i in plural. Hard consonants: p, b, t, d, n, l, s, z.",
      "table": {
        "headers": ["Singular", "Plural", "Meaning", "Pattern"],
        "rows": [
          ["muž", "muži", "man/men", "muž + i"],
          ["študent", "študenti", "student/students", "študent + i"],
          ["pes", "psi", "dog/dogs", "pes + i"],
          ["syn", "synovia", "son/sons", "irregular"],
          ["priateľ", "priatelia", "friend/friends", "soft → ia"],
          ["doktor", "doktori", "doctor/doctors", "doktor + i"],
          ["profesor", "profesori", "professor/professors", "profesor + i"]
        ]
      },
      "examples": [
        "muž → muži (men)",
        "študent → študenti (students)",
        "pes → psi (dogs)",
        "doktor → doktori (doctors)"
      ]
    },
